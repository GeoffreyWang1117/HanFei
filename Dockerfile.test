# Test: hanfei-shu runs WITHOUT CUDA Toolkit installed.
# Only needs: NVIDIA driver (provides libcudart) + Rust.
#
# Build:  docker build -f Dockerfile.test -t hanfei-test .
# Run:    docker run --gpus all hanfei-test
#
# Expected: GPU detected, tests pass, examples run.
# If no GPU: CPU fallback, tests still pass.

FROM rust:1.82-slim

# Install minimal runtime deps (NO cuda-toolkit, NO nvcc)
RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .

# Build (should succeed without nvcc — uses prebuilt kernels)
RUN cargo build --release 2>&1 | tail -5

# Run lib tests
CMD ["sh", "-c", "echo '=== hanfei-shu Docker test ===' && \
    echo 'No CUDA Toolkit installed (only driver runtime via --gpus all)' && \
    cargo test --release --lib -- --nocapture && \
    echo '' && \
    echo '=== CPU vs GPU example ===' && \
    cargo run --release --example cpu_vs_gpu 2>&1 | head -20 && \
    echo '' && \
    echo '=== All tests passed ==='"]
